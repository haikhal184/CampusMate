# ==========================================
# KONFIGURASI BACKEND CAMPUSMATE AI
# ==========================================

# 1. Konfigurasi Server API (FastAPI)
API_HOST=127.0.0.1
API_PORT=8000
ENVIRONMENT=development

# 2. Konfigurasi Mesin LLM (Ollama)
# URL default tempat Ollama berjalan di komputer lokal
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Nama model yang digunakan (Sangat ringan dan cepat)
LLM_MODEL_NAME=qwen2.5:1.5b

# 3. Konfigurasi Model Embedding (HuggingFace)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# 4. Konfigurasi Direktori RAG (Vector Database & Dokumen)
CHROMA_DB_PATH=data/chroma_db
RAW_DATA_PATH=data/raw

# 5. Konfigurasi Keamanan (CORS)
# URL frontend Vue.js agar diizinkan mengakses API (biasanya port 5173 untuk Vite/Vue)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173